generator client {
  provider        = "prisma-client-js"
  runtime         = "nodejs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasks          Task[]
  projects       Project[]
  notes          Note[]
  messages       Message[]
  meetings       Meeting[] @relation("MeetingOrganizer")
  agentLogs      AgentLog[]
  routines       Routine[]
  knowledgeNotes KnowledgeNote[]

  @@map("users")
}

model Task {
  id            String      @id @default(cuid())
  name          String
  description   String?
  status        TaskStatus  @default(PENDING)
  priority      Priority    @default(MEDIUM)
  dueDate       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  userId        String
  user          User        @relation(fields: [userId], references: [id])

  projectId     String?
  project       Project?    @relation(fields: [projectId], references: [id])

  thread        Thread?
  meetingId     String?
  meeting       Meeting?    @relation(fields: [meetingId], references: [id])

  dependsOn     TaskDependency[] @relation("DependentTask")
  dependedBy    TaskDependency[] @relation("DependencyTarget")

  embedding     Unsupported("vector(1536)")?
  topics        TaskTopic[]
  routineSteps  RoutineStep[]

  @@index([userId, status])
  @@index([projectId])
  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  REVIEW
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model TaskDependency {
  id            String  @id @default(cuid())
  taskId        String
  dependsOnId   String

  task          Task    @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn     Task    @relation("DependencyTarget", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

model Project {
  id            String    @id @default(cuid())
  name          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  tasks         Task[]
  thread        Thread?
  meetings      Meeting[]

  @@index([userId])
  @@map("projects")
}

model Thread {
  id            String    @id @default(cuid())
  entityType    String    // "task" | "project"
  entityId      String
  createdAt     DateTime  @default(now())

  taskId        String?   @unique
  task          Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  projectId     String?   @unique
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages      Message[]

  @@map("threads")
}

model Message {
  id            String    @id @default(cuid())
  content       String
  authorType    String    // "user" | "agent"
  createdAt     DateTime  @default(now())

  threadId      String
  thread        Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorId      String?
  author        User?     @relation(fields: [authorId], references: [id])

  agentType     String?

  @@index([threadId, createdAt])
  @@map("messages")
}

model Meeting {
  id            String        @id @default(cuid())
  title         String
  description   String?
  scheduledAt   DateTime
  duration      Int
  meetUrl       String?
  googleEventId String?
  status        MeetingStatus @default(SCHEDULED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  organizerId   String
  organizer     User          @relation("MeetingOrganizer", fields: [organizerId], references: [id])

  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])

  tasks         Task[]
  summary       MeetingSummaryRecord?
  topics        MeetingTopic[]

  @@index([organizerId, scheduledAt])
  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model MeetingSummaryRecord {
  id            String    @id @default(cuid())
  overview      String
  decisions     Json
  actionItems   Json
  createdAt     DateTime  @default(now())

  meetingId     String    @unique
  meeting       Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  embedding     Unsupported("vector(1536)")?

  @@map("meeting_summaries")
}

model Note {
  id            String    @id @default(cuid())
  title         String
  content       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  outgoingLinks NoteLink[] @relation("SourceNote")
  incomingLinks NoteLink[] @relation("TargetNote")

  entityLinks   NoteEntityLink[]

  embedding     Unsupported("vector(1536)")?
  topics        NoteTopic[]

  @@index([userId])
  @@map("notes")
}

model NoteLink {
  id            String    @id @default(cuid())
  sourceNoteId  String
  targetNoteId  String?
  targetTitle   String
  createdAt     DateTime  @default(now())

  sourceNote    Note      @relation("SourceNote", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  targetNote    Note?     @relation("TargetNote", fields: [targetNoteId], references: [id], onDelete: SetNull)

  @@unique([sourceNoteId, targetTitle])
  @@map("note_links")
}

model NoteEntityLink {
  id            String    @id @default(cuid())
  noteId        String
  entityType    String    // "task" | "project" | "meeting"
  entityId      String
  createdAt     DateTime  @default(now())

  note          Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, entityType, entityId])
  @@map("note_entity_links")
}

model AgentLog {
  id            String    @id @default(cuid())
  requestId     String
  agent         String
  action        String
  input         Json
  output        Json?
  status        String
  tokensUsed    Int?
  latencyMs     Int?
  costEstimate  Float?
  createdAt     DateTime  @default(now())

  userId        String
  user          User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([agent, createdAt])
  @@map("agent_logs")
}

// ─── Topics (Second Brain Themes) ─────────────────────────────────

model Topic {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  color     String?
  icon      String?
  lifeArea  LifeArea  @default(PERSONAL)
  summary   String?
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent          Topic?          @relation("TopicHierarchy", fields: [parentId], references: [id])
  children        Topic[]         @relation("TopicHierarchy")
  notes           NoteTopic[]
  tasks           TaskTopic[]
  meetings        MeetingTopic[]
  knowledgeNotes  KnowledgeNote[]
  routines        RoutineTopic[]

  @@map("topics")
}

// ─── KnowledgeNote (Unified knowledge entity) ─────────────────────

model KnowledgeNote {
  id        String              @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  type      KnowledgeNoteType
  status    KnowledgeNoteStatus @default(DRAFT)
  topicId   String?
  tags      String[]
  metadata  Json?
  priority  Priority?
  userId    String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  topic     Topic?              @relation(fields: [topicId], references: [id])
  user      User                @relation(fields: [userId], references: [id])

  edgesFrom KnowledgeEdge[]     @relation("EdgeFrom")
  edgesTo   KnowledgeEdge[]     @relation("EdgeTo")
  sources   ResearchSource[]

  embedding Unsupported("vector(1536)")?

  @@index([userId, type])
  @@index([topicId])
  @@index([userId, status])
  @@map("knowledge_notes")
}

// ─── ResearchSource (linked to KnowledgeNote of type RESEARCH) ────

model ResearchSource {
  id                String         @id @default(cuid())
  knowledgeNoteId   String
  title             String
  url               String
  excerpt           String?
  createdAt         DateTime       @default(now())

  knowledgeNote     KnowledgeNote  @relation(fields: [knowledgeNoteId], references: [id], onDelete: Cascade)

  @@map("research_sources")
}

enum KnowledgeNoteType {
  NOTE
  RESEARCH
  RESEARCH_DRAFT
  CHECKLIST
  GUIDE
  JOURNAL
  RESOURCE
  RECIPE
  TRAVEL_TEMPLATE
  GARDEN_LOG
  LEARNING
  CULTURAL_NOTE
  MEETING_NOTE
  IDEA
  ROUTINE_NOTE
  ACTION_ITEM
}

enum KnowledgeNoteStatus {
  DRAFT
  ACTIVE
  COMPLETED
  PUBLISHED
  ARCHIVED
}

// ─── KnowledgeEdge (Graph relations) ──────────────────────────────

model KnowledgeEdge {
  id           String           @id @default(cuid())
  fromId       String
  toId         String
  relationType EdgeRelationType
  createdAt    DateTime         @default(now())

  from         KnowledgeNote    @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to           KnowledgeNote    @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relationType])
  @@index([fromId])
  @@index([toId])
  @@map("knowledge_edges")
}

enum EdgeRelationType {
  REFERENCES
  DERIVED_FROM
  RELATED_TO
  SUPPORTS
  CONTRADICTS
  BELONGS_TO_TOPIC
  GENERATED_FROM
  APPLIES_TO
  REQUIRES
  INSPIRED_BY
}

// ─── RoutineTopic (link routines to topics) ───────────────────────

model RoutineTopic {
  id        String @id @default(cuid())
  routineId String
  topicId   String

  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
  topic     Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([routineId, topicId])
  @@map("routine_topics")
}

model NoteTopic {
  id      String @id @default(cuid())
  noteId  String
  topicId String

  note  Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([noteId, topicId])
  @@map("note_topics")
}

model TaskTopic {
  id      String @id @default(cuid())
  taskId  String
  topicId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([taskId, topicId])
  @@map("task_topics")
}

model MeetingTopic {
  id        String @id @default(cuid())
  meetingId String
  topicId   String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([meetingId, topicId])
  @@map("meeting_topics")
}

// ─── Routines ─────────────────────────────────────────────────────

model Routine {
  id          String          @id @default(cuid())
  name        String
  category    RoutineCategory
  description String?
  isActive    Boolean         @default(true)
  daysOfWeek  Json?
  timeWindow  String?
  userId      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id])
  steps       RoutineStep[]
  executions  RoutineExecution[]
  topics      RoutineTopic[]

  @@index([userId, isActive])
  @@map("routines")
}

enum RoutineCategory {
  MORNING
  EVENING
  WORKOUT
  SKINCARE
  CUSTOM
}

model RoutineStep {
  id               String   @id @default(cuid())
  routineId        String
  order            Int
  title            String
  description      String?
  estimatedMinutes Int?
  linkedTaskId     String?

  linkedTask       Task?    @relation(fields: [linkedTaskId], references: [id])
  routine          Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId, order])
  @@map("routine_steps")
}

model RoutineExecution {
  id          String        @id @default(cuid())
  routineId   String
  date        DateTime
  status      RoutineStatus @default(COMPLETED)
  notes       String?
  metadata    Json?

  routine     Routine       @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId, date])
  @@map("routine_executions")
}

enum RoutineStatus {
  COMPLETED
  PARTIAL
  SKIPPED
}

// ─── HyperBrain Extension ─────────────────────────────────────────

enum LifeArea {
  SCIENTIFIC
  TECH
  CULTURAL
  PERSONAL
  PHILOSOPHICAL
  ECONOMIC
}

enum LearningType {
  FACT
  INSIGHT
  SKILL
  REFLECTION
  QUOTE
}

enum LearningSource {
  BOOK
  ARTICLE
  EXPERIENCE
  VIDEO
  CONVERSATION
}

model Learning {
  id          String         @id @default(cuid())
  content     String         @db.VarChar(500)
  type        LearningType
  source      LearningSource
  topicId     String?
  researchId  String?
  bookId      String?
  userId      String
  createdAt   DateTime       @default(now())

  @@index([userId, createdAt])
  @@map("learnings")
}

model Book {
  id          String     @id @default(cuid())
  title       String
  author      String
  isbn        String?
  coverUrl    String?
  status      String     // wishlist | reading | completed
  progress    Int        @default(0)
  rating      Int?
  myTake      String?
  source      String     // physical | kindle | pdf
  startDate   DateTime?
  finishDate  DateTime?
  topics      String[]
  userId      String
  createdAt   DateTime   @default(now())

  @@index([userId, status])
  @@map("books")
}
